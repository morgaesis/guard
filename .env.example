# guard environment configuration
# Copy to .env and fill in required values.

# --- Required ---

# LLM API key for command evaluation. Supports OpenRouter or any OpenAI-compatible endpoint.
GUARD_LLM_API_KEY=
# Or use: OPENROUTER_API_KEY=

# --- Optional (defaults shown) ---

# LLM endpoint URL.
# GUARD_LLM_API_URL=https://openrouter.ai/api/v1/chat/completions

# Model for command evaluation.
# GUARD_LLM_MODEL=openai/gpt-5.4-mini
# Optional fallback chain; when set, it takes precedence over GUARD_LLM_MODEL.
# GUARD_LLM_MODELS=openai/gpt-5.4-mini,meta-llama/llama-4-maverick

# Evaluation mode: readonly, safe, or paranoid.
# GUARD_MODE=readonly

# LLM call timeout in seconds.
# GUARD_LLM_TIMEOUT=30

# Shared token for TCP clients.
# GUARD_AUTH_TOKEN=
# Separate token for TCP admin RPCs such as guard grant/status.
# GUARD_ADMIN_TOKEN=

# Learn static allow rules from repeated low-risk LLM approvals.
# GUARD_LEARN_RULES=false
# GUARD_LEARN_MIN_APPROVALS=2
# GUARD_LEARN_MAX_RISK=2
# GUARD_LEARN_SHIMS=suggest

# Path to additive prompt file (appended to the base prompt).
# GUARD_PROMPT_APPEND=

# Consequence gating: off (default) or consequence. When enabled, LLM-approved
# commands are routed by reversibility (reversible runs now, recoverable runs
# behind an auto-revert envelope, irreversible is held for operator approval).
# Requires a local listener (--socket: a Unix-domain socket on Unix, a named
# pipe on Windows); refused over TCP.
# GUARD_GATE=off

# Path to the verb catalog YAML (operator-defined typed operations agents call
# via `guard verb`). Hot-reloaded on change. See examples/verbs.yaml.
# GUARD_VERBS=

# Auto-learn deny shapes from repeated LLM denials and fast-reject matching
# commands without another LLM call. On by default -- unlike GUARD_LEARN_RULES,
# this never grants anything, so it needs no operator promotion step.
# GUARD_LEARN_DENY=true
# GUARD_LEARN_DENY_MIN_DENIALS=3

# Auto-promote trusted verbs from repeated low-risk LLM approvals (requires
# GUARD_GATE=consequence). On by default; restricted to reversible/
# recoverable-with-a-validated-revert shapes, never irreversible.
# GUARD_LEARN_ALLOW=true
# GUARD_LEARN_ALLOW_MIN_APPROVALS=5

# Secret backend: pass, env, local, vault, or infisical (auto-detected if unset).
# GUARD_BACKEND=
# Vault (GUARD_BACKEND=vault): KV v2 over the HTTP API.
# VAULT_ADDR=https://vault.example.com:8200
# VAULT_TOKEN=            # or AppRole: VAULT_ROLE_ID + VAULT_SECRET_ID
# VAULT_KV_MOUNT=secret   # default
# VAULT_NAMESPACE=        # optional (Vault Enterprise)
# Infisical (GUARD_BACKEND=infisical): Universal Auth machine identity.
# INFISICAL_API_URL=https://app.infisical.com
# INFISICAL_CLIENT_ID=
# INFISICAL_CLIENT_SECRET=
# INFISICAL_PROJECT_ID=
# INFISICAL_ENVIRONMENT=prod

# Owner principal the daemon reads its own LLM_API_KEY secret under when no key
# is supplied by flag or env (lets the daemon source its key from the backend).
# GUARD_SERVER_UID=

# Comma-separated binary allow-list. When set, only these binaries may execute,
# on every route, regardless of the LLM decision.
# GUARD_ALLOW_BIN=kubectl,git,helm

# Kubernetes API proxy: front the apiserver and gate in-process API clients
# (helm, kubectl, terraform, k9s) at the API boundary. Listen address enables it.
# GUARD_KUBE_PROXY=127.0.0.1:8443
# The operator's real kubeconfig (the daemon holds these credentials).
# GUARD_KUBE_PROXY_KUBECONFIG=/etc/guard/kubeconfig
# Context to use upstream (default: the kubeconfig's current-context).
# GUARD_KUBE_CONTEXT=
# Operator API policy, hot-reloaded (see examples/api-policy.yaml). Default-deny if unset.
# GUARD_API_POLICY=/etc/guard/api-policy.yaml
# Write the agent-facing brokered kubeconfig here (points at the proxy, no credential).
# GUARD_BROKERED_KUBECONFIG_OUT=/run/guard/brokered.kubeconfig

# GPG recipient for secret encryption (local backend).
# GUARD_GPG_RECIPIENT=

# LLM retries per model on transient failures (1-2).
# GUARD_LLM_RETRIES=2

# In-memory LLM decision cache (keyed on the exact command line).
# GUARD_CACHE=true
# GUARD_CACHE_CAPACITY=1024
# GUARD_CACHE_TTL=3600

# Deterministic pre-LLM checks: executable-exists on PATH and
# credential-disclosure pattern deny. Coarse by design; off by default.
# GUARD_PREFLIGHT=false

# SQLite state database (sessions, holds, provisionals, read grants).
# Default: $XDG_STATE_HOME/guard/state.db or ~/.local/state/guard/state.db.
# GUARD_STATE_DB=

# Named session-grant profiles for `guard session new --profile <name>`.
# See examples/session-profiles.yaml. Hot-reloaded.
# GUARD_PROFILES=

# Comma-separated daemon env vars forwarded to brokered children (values come
# from the daemon's environment, never the caller's).
# GUARD_CHILD_ENV=KUBECONFIG

# Run brokered children as the calling uid instead of the daemon account
# (Unix, root-owned socket daemons only).
# GUARD_EXEC_AS_CALLER=false

# Paths for the auto-learned deny-shape and verb-promotion state.
# GUARD_DENY_SHAPES=
# GUARD_LEARN_ALLOW_STATE=

# Evaluate policy but do not execute approved commands.
# GUARD_DRY_RUN=false

# Daemon log level (error, warn, info, debug, trace).
# GUARD_LOG_LEVEL=info

# Bearer token for the HTTP MCP transport (guard mcp serve --http).
# GUARD_MCP_TOKEN=
