# guard systemd service environment
# Install to /etc/default/guard
#
# This file covers the variables relevant to the packaged systemd unit, which
# serves local clients over a UNIX socket. See .env.example in the repository
# root for the complete variable catalog.

# --- Required ---

# LLM API key for command evaluation.
GUARD_LLM_API_KEY=

# --- Optional (defaults shown) ---

# Emit startup paths and runtime configuration to the systemd journal.
RUST_LOG=info

# LLM endpoint URL.
# GUARD_LLM_API_URL=https://openrouter.ai/api/v1/chat/completions

# Primary model for command evaluation.
# GUARD_LLM_MODEL=openai/gpt-5.4-mini

# Optional fallback chain (comma-separated). When set, takes precedence over
# GUARD_LLM_MODEL above.
# GUARD_LLM_MODELS=openai/gpt-5.4-mini,meta-llama/llama-4-maverick

# Evaluation mode: readonly, safe, or paranoid.
# GUARD_MODE=readonly

# LLM call timeout in seconds.
# GUARD_LLM_TIMEOUT=30

# Path to additive prompt file (appended to the base prompt).
# GUARD_PROMPT_APPEND=

# Over the unit's UNIX socket, admin RPCs (session grant/revoke/list, the full
# status snapshot) are restricted to the daemon's own UID; no environment
# variable or token elevates another local caller. GUARD_AUTH_TOKEN and
# GUARD_ADMIN_TOKEN apply only to TCP listeners, which this unit does not use
# (see .env.example).
