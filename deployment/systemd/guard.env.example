# guard systemd service environment
# Install to /etc/default/guard

# --- Required ---

# LLM API key for command evaluation.
SSH_GUARD_LLM_API_KEY=

# --- Optional (defaults shown) ---

# LLM endpoint URL. SSH_GUARD_API_URL is accepted as a compatibility alias.
# SSH_GUARD_LLM_API_URL=https://openrouter.ai/api/v1/chat/completions

# Primary model for command evaluation.
# SSH_GUARD_LLM_MODEL=openai/gpt-5.4-nano

# Optional fallback chain (comma-separated). When set, takes precedence over
# SSH_GUARD_LLM_MODEL above because a chain is an explicit opt-in to
# multi-model evaluation.
# SSH_GUARD_LLM_MODELS=openai/gpt-5.4-nano,meta-llama/llama-4-maverick

# Retries per model on transient failures.
# SSH_GUARD_LLM_RETRIES=2

# Evaluation mode: readonly, safe, or paranoid.
# SSH_GUARD_MODE=readonly

# Evaluate policy but do not execute approved commands.
# SSH_GUARD_DRY_RUN=false

# LLM call timeout in seconds. SSH_GUARD_TIMEOUT is accepted as a compatibility alias.
# SSH_GUARD_LLM_TIMEOUT=30

# Path to additive prompt file (appended to the base prompt).
# SSH_GUARD_PROMPT_APPEND=

# Persistent state database for session grants/history.
# SSH_GUARD_STATE_DB=

# Secret backend: pass, env, or local (auto-detected if not set).
# SSH_GUARD_BACKEND=

# GPG recipient for local secret encryption.
# SSH_GUARD_GPG_RECIPIENT=

# Enable deterministic pre-LLM checks: executable-exists on PATH and
# credential-disclosure pattern deny. These are coarse and can over-match
# (they block any command containing the `env` token). Leave off to let the
# LLM be the sole decision authority; turn on for hosts where LLM cost or
# latency dominates over false positives.
# SSH_GUARD_PREFLIGHT=false

# In-memory cache of LLM decisions. A command approved once returns from
# cache on subsequent requests within the TTL without another LLM call.
# Cache is cleared on daemon restart and on any prompt file change that
# forces a new Evaluator. Set SSH_GUARD_CACHE=false to disable.
# SSH_GUARD_CACHE=true
# SSH_GUARD_CACHE_CAPACITY=1024
# SSH_GUARD_CACHE_TTL=3600

# Execute approved children as the connecting Unix UID. Requires root daemon
# startup and a Unix socket only.
# SSH_GUARD_EXEC_AS_CALLER=false

# Admin RPCs (session grant/revoke/list, full status snapshot) are
# restricted to the daemon's own UID. There is no env var or token to
# elevate a client.
