# Self-contained adversarial harness for consequence gating.
# Builds guard for Linux, sets up an unprivileged daemon (uid 1000) and agent (uid 1001),
# and runs the attack script. The harness uses deterministic local fixtures and
# makes no external service calls.
#
# Build context is the repo root. `.dockerignore` restricts the context to the
# source and fixture paths this harness copies.
FROM docker.io/library/rust@sha256:77fac8b98f9f46062bb680b6d25d5bcaabfc400143952ebc572e924bcbedc3fa

WORKDIR /src
ARG CARGO_BUILD_JOBS=1
ENV CARGO_BUILD_JOBS=${CARGO_BUILD_JOBS}
# Copy only what the build needs (keeps the Windows target/ out of the image).
# `tests/` is required so `run.sh test` actually compiles and runs the
# integration test binaries (e.g. mcp_integration) - without it the suite
# silently covers only the lib/bin unit tests. `examples/` is required because
# policy_tests embeds example policy files via include_str!("../examples/...").
COPY Cargo.toml Cargo.lock build.rs deny.toml ./
COPY src ./src
COPY config ./config
COPY tests ./tests
COPY examples ./examples

RUN cargo build --release --locked --quiet \
    && install -m 0755 target/release/guard /usr/local/bin/guard \
    && rm -rf target

# Two distinct identities: the daemon/operator (uid 1000) and the agent (uid
# 1001). The gate's bypass-resistance holds precisely because they differ.
RUN useradd -m -u 1000 guarddaemon && useradd -m -u 1001 agent

COPY ctf/gating/verbs.yaml /etc/guard/verbs.yaml
RUN chmod 0644 /etc/guard/verbs.yaml
COPY ctf/gating/attack.sh /attack.sh
RUN chmod 0755 /attack.sh

# Default: run the adversarial attack. Use the harness script's `test` mode to
# run the full Linux test suite with the entrypoint overridden.
ENTRYPOINT ["/attack.sh"]
